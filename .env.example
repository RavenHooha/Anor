EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional. If unset, the feature is simply disabled.
EXPO_PUBLIC_POSTHOG_KEY=phc_your-posthog-project-key
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# RevenueCat public SDK keys (safe to embed — client keys, not secrets).
# Use the test-store key (test_…) while developing; swap to the real Google
# Play public key for production. If unset, in-app purchases are disabled.
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=

# Dev-only convenience login. Shown ONLY in __DEV__ builds (the "Skip (dev)"
# button on the auth screen). Do NOT set these in EAS production build env.
EXPO_PUBLIC_DEV_EMAIL=
EXPO_PUBLIC_DEV_PASSWORD=
