EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional. If unset, the feature is simply disabled.
EXPO_PUBLIC_POSTHOG_KEY=phc_your-posthog-project-key
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# Dev-only convenience login. Shown ONLY in __DEV__ builds (the "Skip (dev)"
# button on the auth screen). Do NOT set these in EAS production build env.
EXPO_PUBLIC_DEV_EMAIL=
EXPO_PUBLIC_DEV_PASSWORD=
